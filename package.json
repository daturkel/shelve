{
  "name": "shelve",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "shared",
    "worker",
    "core",
    "extension"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "sharp@0.34.5": true,
    "workerd@1.20260708.1": true,
    "fsevents@2.3.2": true,
    "sharp@0.33.5": true,
    "workerd@1.20251011.0": true,
    "esbuild@0.25.4": true
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "typescript-eslint": "^8.64.0"
  }
}
