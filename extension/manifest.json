{
  "manifest_version": 3,
  "name": "Shelve",
  "version": "0.3.0",
  "description": "Save tabs into folders, synced across your devices via your own Cloudflare Worker + D1 backend.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Shelve"
  },
  "options_page": "options/index.html"
}
